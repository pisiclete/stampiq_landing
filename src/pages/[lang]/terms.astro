---
import Layout from '../../layouts/Layout.astro';
import TermsPage from '../../components/legal/TermsPage.jsx';
import { tFor } from '../../i18n/lookup.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pl' } },
  ];
}

const { lang } = Astro.params;
const title = tFor(lang, 'terms.page_title');
const description = tFor(lang, 'terms.meta_description');
const canonical = `https://stampiq.io/${lang}/terms.html`;
---
<Layout {lang} {title} {description} {canonical}>
  <TermsPage {lang} client:load />
</Layout>
