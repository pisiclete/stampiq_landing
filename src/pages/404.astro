---
// 404 page, doubling as the scan-promo QR fallback.
//
// A promo QR encodes https://stampiq.io/r/<CODE>. On a phone with the app
// installed the OS opens the app via the universal/app link — on iOS the QR
// usually routes through Safari, which (14.2+) auto-bounces into the app. When
// that happens this tab is backgrounded, so we detect it and show a "you're all
// set" state rather than action buttons (the redemption already ran in-app).
// When the app never opens (not installed, or the link didn't fire) the tab
// stays visible and we reveal a manual "Open in app" button (the stampiq://
// custom scheme, which works from a loaded page where a same-domain universal
// link will not) plus a store button to install. No auto-redirect — an
// automatic store redirect races the app launch and bounces the user to the
// store after the app has already opened. Other unknown paths fall through home.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StampIQ</title>
    <style>
      body {
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f9f9f9;
        color: #222222;
      }
      .card {
        text-align: center;
        padding: 24px;
        max-width: 320px;
        width: 100%;
      }
      .title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 24px;
      }
      .btn {
        display: block;
        width: 100%;
        box-sizing: border-box;
        padding: 14px 16px;
        margin: 12px 0;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
      }
      .btn.primary {
        background-color: #66e204;
        color: #ffffff;
      }
      .btn.secondary {
        background-color: #ffffff;
        color: #222222;
        border: 1px solid #e0e0e0;
      }
      .muted {
        margin-top: 24px;
      }
      .muted a {
        color: #888888;
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <p class="title" id="title">Opening StampIQ…</p>
      <div id="actions" style="display: none">
        <a id="openApp" class="btn primary" href="#">Open in StampIQ</a>
        <a id="getApp" class="btn secondary" href="#">Get the app</a>
      </div>
      <p class="muted"><a href="/">Continue to the website</a></p>
    </div>

    <script is:inline>
      (function () {
        var ua = navigator.userAgent || '';
        var path = location.pathname || '';
        var APP_STORE = 'https://apps.apple.com/app/id6760778035';
        var PLAY_STORE =
          'https://play.google.com/store/apps/details?id=io.stampiq.app';

        var isPromo = /^\/r\//.test(path);
        if (!isPromo) {
          location.replace('/');
          return;
        }

        var isAndroid = /android/i.test(ua);
        var title = document.getElementById('title');
        var actions = document.getElementById('actions');
        document.getElementById('openApp').href = 'stampiq:/' + path;
        document.getElementById('getApp').href = isAndroid
          ? PLAY_STORE
          : APP_STORE;

        // If the tab is (or becomes) hidden, the OS opened the app — the
        // redemption already ran in-app, so confirm rather than prompt.
        var appOpened = document.hidden;
        function settled() {
          appOpened = true;
          actions.style.display = 'none';
          title.textContent = "You're all set — switch back to StampIQ.";
        }
        if (appOpened) settled();
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) settled();
        });

        // If the app never took over, it isn't installed (or the link didn't
        // fire): show the manual open / install buttons.
        setTimeout(function () {
          if (!appOpened && !document.hidden) {
            title.textContent = 'Open StampIQ to claim your bonus scans';
            actions.style.display = 'block';
          }
        }, 1500);
      })();
    </script>
  </body>
</html>
