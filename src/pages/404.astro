---
// 404 page, doubling as the scan-promo QR fallback.
//
// A promo QR encodes https://stampiq.io/r/<CODE>. When the app is installed the
// OS opens it via the universal/app link — but Safari still loads this page in
// parallel, so a redirect can race the app launch and bounce the user to the
// store after the app already opened. We delay the store redirect briefly and
// cancel it if the page is backgrounded (which happens when the app takes over).
// When the app is NOT installed the page stays visible, the timer fires, and we
// send the visitor to the right store to install — they rescan after signing up.
// Any other unknown path falls through to the homepage immediately.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StampIQ</title>
    <style>
      body {
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f9f9f9;
        color: #222222;
      }
      .redirect-message {
        text-align: center;
        padding: 20px;
      }
      a {
        color: #66e204;
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="redirect-message">
      <p>Opening StampIQ…</p>
      <p><a href="/">Continue to the website</a></p>
    </div>

    <script is:inline>
      (function () {
        var ua = navigator.userAgent || '';
        var path = location.pathname || '';
        var APP_STORE = 'https://apps.apple.com/app/id6760778035';
        var PLAY_STORE =
          'https://play.google.com/store/apps/details?id=io.stampiq.app';

        var isPromo = /^\/r\//.test(path);
        var isIOS = /iPad|iPhone|iPod/.test(ua);
        var isAndroid = /android/i.test(ua);

        if (!isPromo || (!isIOS && !isAndroid)) {
          location.replace('/');
          return;
        }

        var store = isIOS ? APP_STORE : PLAY_STORE;
        var timer = setTimeout(function () {
          location.replace(store);
        }, 1500);

        function cancel() {
          if (document.hidden) clearTimeout(timer);
        }
        document.addEventListener('visibilitychange', cancel);
        window.addEventListener('pagehide', function () {
          clearTimeout(timer);
        });
      })();
    </script>
  </body>
</html>
