---
// 404 page, doubling as the scan-promo QR fallback.
//
// A promo QR encodes https://stampiq.io/r/<CODE>. On a phone with the app
// installed the OS opens the app via the universal/app link and redeems on the
// first scan — so this page only matters when the app is NOT installed: it
// points the visitor to the right store to install (they rescan after signing
// up). It deliberately does nothing automatic: an auto store redirect races the
// app launch and bounces an already-opened app to the store, and re-triggering
// the app (e.g. via a custom scheme) re-runs redemption and stacks dialogs.
// Installed users may briefly see this page if iOS leaves Safari on it after the
// QR routes through the browser; the app has already opened, so they just switch
// back. Any other unknown path falls through to the homepage.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StampIQ</title>
    <style>
      body {
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f9f9f9;
        color: #222222;
      }
      .card {
        text-align: center;
        padding: 24px;
        max-width: 320px;
        width: 100%;
      }
      .title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 24px;
      }
      .btn {
        display: block;
        width: 100%;
        box-sizing: border-box;
        padding: 14px 16px;
        margin: 12px 0;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        background-color: #66e204;
        color: #ffffff;
      }
      .muted {
        margin-top: 24px;
      }
      .muted a {
        color: #888888;
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <p class="title">Get StampIQ to claim your bonus scans</p>
      <a id="getApp" class="btn" href="https://apps.apple.com/app/id6760778035"
        >Get the app</a
      >
      <p class="muted"><a href="/">Continue to the website</a></p>
    </div>

    <script is:inline>
      (function () {
        var path = location.pathname || '';
        if (!/^\/r\//.test(path)) {
          location.replace('/');
          return;
        }
        if (/android/i.test(navigator.userAgent || '')) {
          document.getElementById('getApp').href =
            'https://play.google.com/store/apps/details?id=io.stampiq.app';
        }
      })();
    </script>
  </body>
</html>
