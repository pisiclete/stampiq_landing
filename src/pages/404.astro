---
// 404 page, doubling as the scan-promo QR fallback.
//
// A promo QR encodes https://stampiq.io/r/<CODE>. When the OS intercepts that as
// a universal/app link it opens the app and this page never loads. But scanning
// a QR often loads the URL in the browser instead, and iOS won't honour a
// same-domain universal link from a loaded page — so from here we hand off via
// the app's custom scheme (stampiq://r/<CODE>), which opens the installed app
// from any page. If nothing handles the scheme the page stays visible and the
// timer sends the visitor to the right store to install (they rescan after
// signing up); if the app opens, the page is backgrounded and we cancel the
// store redirect. Any other unknown path falls through to the homepage.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StampIQ</title>
    <style>
      body {
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f9f9f9;
        color: #222222;
      }
      .redirect-message {
        text-align: center;
        padding: 20px;
      }
      a {
        color: #66e204;
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="redirect-message">
      <p>Opening StampIQ…</p>
      <p><a href="/">Continue to the website</a></p>
    </div>

    <script is:inline>
      (function () {
        var ua = navigator.userAgent || '';
        var path = location.pathname || '';
        var APP_STORE = 'https://apps.apple.com/app/id6760778035';
        var PLAY_STORE =
          'https://play.google.com/store/apps/details?id=io.stampiq.app';

        var isPromo = /^\/r\//.test(path);
        var isIOS = /iPad|iPhone|iPod/.test(ua);
        var isAndroid = /android/i.test(ua);

        if (!isPromo || (!isIOS && !isAndroid)) {
          location.replace('/');
          return;
        }

        var store = isIOS ? APP_STORE : PLAY_STORE;

        // Send installed apps straight in via the custom scheme — unlike a
        // same-domain universal link, it works even though this page has loaded.
        // If nothing handles it the page stays visible and we fall back to the
        // store; if the app opens the page is backgrounded and we cancel.
        var timer = setTimeout(function () {
          location.replace(store);
        }, 1500);

        function cancel() {
          clearTimeout(timer);
        }
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) cancel();
        });
        window.addEventListener('pagehide', cancel);

        location.href = 'stampiq:/' + path;
      })();
    </script>
  </body>
</html>
