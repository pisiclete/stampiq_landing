---
// 404 page, doubling as the scan-promo QR fallback.
//
// A promo QR encodes https://stampiq.io/r/<CODE>. On a phone with the app
// installed, iOS/Android open the app via the universal/app link and this page
// never shows (on iOS 14.2+ even a QR that lands in Safari is auto-bounced into
// the app). This page is the fallback for when that doesn't happen: it offers a
// manual "Open in app" button (the stampiq:// custom scheme, which works from a
// loaded page where a same-domain universal link will not) and a store button to
// install. No auto-redirect — an automatic store redirect races the app launch
// and bounces the user to the store after the app has already opened.
// Any other unknown path falls through to the homepage.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StampIQ</title>
    <style>
      body {
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f9f9f9;
        color: #222222;
      }
      .card {
        text-align: center;
        padding: 24px;
        max-width: 320px;
        width: 100%;
      }
      .title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 24px;
      }
      .btn {
        display: block;
        width: 100%;
        box-sizing: border-box;
        padding: 14px 16px;
        margin: 12px 0;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
      }
      .btn.primary {
        background-color: #66e204;
        color: #ffffff;
      }
      .btn.secondary {
        background-color: #ffffff;
        color: #222222;
        border: 1px solid #e0e0e0;
      }
      .muted {
        margin-top: 24px;
      }
      .muted a {
        color: #888888;
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <p class="title">Open StampIQ to claim your bonus scans</p>
      <a id="openApp" class="btn primary" href="#">Open in StampIQ</a>
      <a id="getApp" class="btn secondary" href="#">Get the app</a>
      <p class="muted"><a href="/">Continue to the website</a></p>
    </div>

    <script is:inline>
      (function () {
        var ua = navigator.userAgent || '';
        var path = location.pathname || '';
        var APP_STORE = 'https://apps.apple.com/app/id6760778035';
        var PLAY_STORE =
          'https://play.google.com/store/apps/details?id=io.stampiq.app';

        var isPromo = /^\/r\//.test(path);
        if (!isPromo) {
          location.replace('/');
          return;
        }

        var isAndroid = /android/i.test(ua);
        document.getElementById('openApp').href = 'stampiq:/' + path;
        document.getElementById('getApp').href = isAndroid
          ? PLAY_STORE
          : APP_STORE;
      })();
    </script>
  </body>
</html>
